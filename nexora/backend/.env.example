# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# ─── Security ─────────────────────────────────────────────────────────────────
# JWT: must be at least 32 characters long
JWT_SECRET=your-minimum-32-character-jwt-secret-key-here
# Encryption: must be exactly 16 characters
ENCRYPTION_KEY=your16charenckey

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ─── Database (optional — defaults to H2 in-memory if not set) ───────────────
# Uncomment to use MySQL instead of H2:
# DB_URL=jdbc:mysql://localhost:3306/nexora_db
# DB_USERNAME=root
# DB_PASSWORD=your_mysql_password
# DB_DRIVER=com.mysql.cj.jdbc.Driver
# DB_DIALECT=org.hibernate.dialect.MySQLDialect
